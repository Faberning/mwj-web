---
import {
	ADVISER,
	BUSINESS,
	FAQ_ENTRIES,
	LICENSEE,
	SAME_AS,
	SITE_URL,
	STATS,
	VIDEO,
} from '../consts';

interface BreadcrumbEntry {
	name: string;
	url: string;
}

interface FaqEntry {
	question: string;
	answer: string;
}

interface ServiceInfo {
	name: string;
	serviceType: string;
	description: string;
	areaServed?: string;
}

interface ItemListInfo {
	name: string;
	items: { name: string; url: string }[];
}

interface Props {
	includeBusiness?: boolean;
	includeFAQ?: boolean;
	faqEntries?: readonly FaqEntry[];
	includeVideo?: boolean;
	profilePage?: boolean;
	breadcrumb?: BreadcrumbEntry[];
	service?: ServiceInfo;
	itemList?: ItemListInfo;
	pageType?: 'WebPage' | 'ContactPage' | 'WebApplication';
	pageName?: string;
	pageDescription?: string;
}

const {
	includeBusiness = true,
	includeFAQ = false,
	faqEntries,
	includeVideo = false,
	profilePage = false,
	breadcrumb,
	service,
	itemList,
	pageType,
	pageName,
	pageDescription,
} = Astro.props;

const licenseeId = `${SITE_URL}/#licensee`;
const personId = `${SITE_URL}/#jj`;
const businessId = `${SITE_URL}/#business`;
const pageUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const pageId = `${pageUrl}#page`;
const breadcrumbId = `${pageUrl}#breadcrumb`;

// Defined once, referenced by @id everywhere else — avoids the repeated
// inline Organization copies that used to collide across provider/worksFor/publisher.
const licensee = {
	'@type': 'Organization',
	'@id': licenseeId,
	name: LICENSEE.name,
	identifier: LICENSEE.fsp,
};

const person = {
	'@type': 'Person',
	'@id': personId,
	name: ADVISER.name,
	jobTitle: ADVISER.title,
	identifier: ADVISER.fsp,
	description: ADVISER.bioDescription,
	worksFor: { '@id': licenseeId },
	sameAs: SAME_AS,
};

const graph: Record<string, unknown>[] = [person, licensee];

if (includeBusiness) {
	graph.push({
		'@type': 'FinancialService',
		'@id': businessId,
		name: BUSINESS.name,
		description: `Senior Mortgage Adviser ${ADVISER.name} — first home buyers, refinance, investment and new build across ${BUSINESS.address.suburb}, the Hibiscus Coast and all of New Zealand.`,
		areaServed: BUSINESS.areaServed,
		telephone: BUSINESS.phoneE164,
		email: BUSINESS.email,
		priceRange: 'No fee to you',
		address: {
			'@type': 'PostalAddress',
			streetAddress: BUSINESS.address.street,
			addressLocality: BUSINESS.address.suburb,
			addressRegion: BUSINESS.address.region,
			postalCode: BUSINESS.address.postcode,
			addressCountry: BUSINESS.address.country,
		},
		aggregateRating: {
			'@type': 'AggregateRating',
			ratingValue: STATS.googleRating.toFixed(1),
			reviewCount: String(STATS.googleReviewCount),
			bestRating: '5',
		},
		provider: { '@id': licenseeId },
		sameAs: SAME_AS,
		employee: { '@id': personId },
	});
}

if (includeFAQ) {
	graph.push({
		'@type': 'FAQPage',
		mainEntity: (faqEntries ?? FAQ_ENTRIES).map((entry) => ({
			'@type': 'Question',
			name: entry.question,
			acceptedAnswer: { '@type': 'Answer', text: entry.answer },
		})),
	});
}

if (includeVideo) {
	graph.push({
		'@type': 'VideoObject',
		name: VIDEO.title,
		description: VIDEO.description,
		thumbnailUrl: `https://i.ytimg.com/vi/${VIDEO.youtubeId}/hqdefault.jpg`,
		uploadDate: '2026-07-14',
		contentUrl: `https://youtu.be/${VIDEO.youtubeId}`,
		embedUrl: `https://www.youtube-nocookie.com/embed/${VIDEO.youtubeId}`,
		publisher: { '@id': licenseeId },
	});
}

if (service) {
	graph.push({
		'@type': 'Service',
		name: service.name,
		serviceType: service.serviceType,
		description: service.description,
		provider: { '@id': businessId },
		...(service.areaServed ? { areaServed: service.areaServed } : {}),
	});
}

if (itemList) {
	graph.push({
		'@type': 'ItemList',
		name: itemList.name,
		itemListElement: itemList.items.map((item, i) => ({
			'@type': 'ListItem',
			position: i + 1,
			name: item.name,
			url: item.url,
		})),
	});
}

if (pageType) {
	graph.push({
		'@type': pageType,
		'@id': pageId,
		name: pageName,
		description: pageDescription,
		...(includeBusiness ? { mainEntity: { '@id': businessId } } : {}),
	});
}

if (profilePage) {
	graph.push({
		'@type': 'ProfilePage',
		'@id': pageId,
		mainEntity: { '@id': personId },
		...(breadcrumb ? { breadcrumb: { '@id': breadcrumbId } } : {}),
	});
}

if (breadcrumb) {
	graph.push({
		'@type': 'BreadcrumbList',
		'@id': breadcrumbId,
		itemListElement: breadcrumb.map((entry, i) => ({
			'@type': 'ListItem',
			position: i + 1,
			name: entry.name,
			item: entry.url,
		})),
	});
}

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': graph,
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
