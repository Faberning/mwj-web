---
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.png';
import { ADVISER, AREAS, BUSINESS, LICENSEE, SERVICES, SITE_URL } from '../consts';
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	showSpine?: boolean;
}

const { title, description, showSpine = true } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL);
const isHome = Astro.url.pathname === '/';

const navLinks = isHome
	? [
			{ href: '#meet', label: 'About JJ' },
			{ href: '#services', label: 'Services' },
			{ href: '/areas/', label: 'Areas' },
			{ href: '#calc', label: 'Calculator' },
			{ href: '#faq', label: 'FAQ' },
		]
	: [
			{ href: '/about/', label: 'About JJ' },
			{ href: '/services/', label: 'Services' },
			{ href: '/areas/', label: 'Areas' },
			{ href: '/mortgage-calculator/', label: 'Calculator' },
			{ href: '/#faq', label: 'FAQ' },
		];
---

<!doctype html>
<html lang="en-NZ">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap"
				rel="stylesheet"
			/>
		</noscript>
		<slot name="head" />
	</head>
	<body>
		{
			showSpine && (
				<div class="spine" aria-hidden="true">
					<svg viewBox="0 0 56 1000" preserveAspectRatio="none">
						<defs>
							<linearGradient id="sg" x1="0" y1="0" x2="0" y2="1">
								<stop offset="0" stop-color="#c9a35e" />
								<stop offset="1" stop-color="#dcba78" />
							</linearGradient>
						</defs>
						<path class="track" d="M28 4 C 6 170, 50 330, 28 500 C 6 670, 50 830, 28 996" />
						<path class="fill" d="M28 4 C 6 170, 50 330, 28 500 C 6 670, 50 830, 28 996" />
					</svg>
					<span class="dot" />
				</div>
			)
		}

		<header class="site">
			<div class="wrap nav">
				<a class="brand" href="/" aria-label="Mortgages with JJ home">
					<Image
						class="logo"
						alt="Mortgages with JJ logo"
						src={logo}
						width={34}
						height={34}
						loading="eager"
					/>
					 Mortgages with <b>JJ</b>
				</a>
				<nav class="nav-links">
					{navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
				</nav>
				<a class="nav-phone" href={`tel:${BUSINESS.phoneE164}`}>{BUSINESS.phoneDisplay}</a>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer>
			<div class="wrap">
				<div class="foot-top">
					<div>
						<div class="brand">Mortgages with <b>JJ</b></div>
						<p>
							Senior Mortgage Adviser JJ van der Westhuizen — helping first home buyers and
							property owners across Orewa, the Hibiscus Coast and all of New Zealand.
						</p>
					</div>
					<div class="foot-col">
						<h4>Services</h4>
						{SERVICES.map((s) => <a href={`/services/${s.slug}/`}>{s.name}</a>)}
						<a href="/services/">All services</a>
					</div>
					<div class="foot-col">
						<h4>Areas</h4>
						{AREAS.map((a) => <a href={`/${a.slug}/`}>{a.name}</a>)}
						<a href="/areas/">All areas</a>
					</div>
					<div class="foot-col">
						<h4>More</h4>
						<a href="/about/">About JJ</a>
						<a href="/contact/">Contact</a>
						<a href="/mortgage-calculator/">Mortgage Calculator</a>
						<a href="/first-home-buyer-guide/">First Home Buyer Guide</a>
						<a href="/blog/">Blog</a>
						<a href={`tel:${BUSINESS.phoneE164}`}>{BUSINESS.phoneDisplay}</a>
						<a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a>
					</div>
				</div>
				<div class="disc">
					<p>
						<b>{ADVISER.name}</b> ({ADVISER.fsp}) is a <b>{ADVISER.title}</b> operating under the
						Financial Advice Provider licence of <b>{LICENSEE.name}</b> ({LICENSEE.fsp}). A copy of
						our publicly available disclosure document is available on request, free of charge.
						This website is general information only and does not constitute personalised
						financial advice. For advice tailored to your specific circumstances, please get in
						touch.
					</p>
				</div>
				<div class="foot-bottom">
					<span>© {new Date().getFullYear()} Mortgages with JJ</span>
					<span><a href="/privacy-policy/">Privacy Policy</a> · <a href="/important-information/">Important Information</a></span>
				</div>
			</div>
		</footer>

		<slot name="scripts" />
	</body>
</html>
